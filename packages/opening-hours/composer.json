{
    "name": "typo3-incubator/opening-hours",
    "type": "typo3-cms-extension",
    "description": "Configure and display opening hours.",
    "keywords": [
        "TYPO3 CMS",
        "opening hours"
    ],
    "require": {
        "typo3/cms-core": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4",
        "typo3/cms-extbase": "^13.4"
    },
    "license": ["GPL-2.0-or-later"],
    "autoload": {
        "psr-4": {
            "TYPO3Incubator\\OpeningHours\\": "Classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "opening_hours"
        }
    }
}
