{
    "name": "typo3-incubator/opening-hours",
    "type": "typo3-cms-extension",
    "description": "Configure and display opening hours.",
    "keywords": [
        "TYPO3 CMS",
        "opening hours"
    ],
    "require": {
        "typo3/cms-core": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4",
        "typo3/cms-extbase": "^13.4"
    },
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.14.0",
		"phpstan/extension-installer": "^1.4",
		"phpstan/phpstan": "^2.0.0",
		"phpstan/phpstan-strict-rules": "^2.0",
		"spaze/phpstan-disallowed-calls": "^4.0",
		"tomasvotruba/type-coverage": "^2.0",
		"typo3/cms-base-distribution": "^13.4",
		"typo3/coding-standards": "^0.8.0"
	},
    "license": ["GPL-2.0-or-later"],
    "autoload": {
        "psr-4": {
            "TYPO3Incubator\\OpeningHours\\": "Classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "opening_hours"
        }
    },
	"scripts": {
		"static-analyse": "vendor/bin/phpstan analyse --xdebug",
		"php-cs-fixer": "vendor/bin/php-cs-fixer fix -v --using-cache=no"
	}
}
