{
    "name": "typo3-incubator/reviews",
    "description": "Organize food and drinks in categories",
    "type": "typo3-cms-extension",
    "require": {
        "typo3/cms-core": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4",
        "typo3/cms-extbase": "^13.4"
    },
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "TYPO3Incubator\\Reviews\\": "Classes/"
        }
    },
    "authors": [
        {
            "name": "Paul Stoske",
            "email": "paul@stoske.eu"
        }
    ],
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "reviews"
        }
    }
}
