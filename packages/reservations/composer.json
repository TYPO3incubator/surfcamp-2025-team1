{
    "name": "typo3-incubator/reservations",
    "description": "Enable reservations and their management",
    "type": "typo3-cms-extension",
    "keywords": [
        "TYPO3 CMS",
        "reservations"
    ],
    "require": {
        "typo3/cms-core": "^13.4",
        "typo3/cms-rte-ckeditor": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4"
    },
    "license": ["GPL-2.0-or-later"],
    "autoload": {
        "psr-4": {
            "TYPO3Incubator\\Reservations\\": "Classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "reservations"
        }
    }
}
